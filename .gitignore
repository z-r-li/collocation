*.vrb

# Scratch / probe scripts (project convention)
_scratch_*.py
_probe_*.py

# Large binaries we don't ship (link to source instead)
*.pptx
*.docx
*.asc

# Matplotlib / numpy caches sometimes dropped by the run scripts
/tmp/
*.tmp
matplotlib-cache/
