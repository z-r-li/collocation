# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.python-version

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# LaTeX intermediates (we keep .tex but not the build cruft)
*.aux
*.fls
*.fdb_latexmk
*.log
*.out
*.synctex.gz
*.toc
*.bbl
*.blg
*.nav
